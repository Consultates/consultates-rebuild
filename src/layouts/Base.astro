---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AI consulting for business leaders. Advisory, training, and fractional executive support.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Canonical URL -->
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
  <meta property="og:image" content={new URL('/images/consultates-head.png', Astro.site).href} />
  <meta property="og:site_name" content="Consultates" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Theme flash prevention — PRD section 6.10, verbatim -->
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      var theme = stored === 'dark' || stored === 'light' ? stored : (stored === 'system' || !stored) ? (prefersDark ? 'dark' : 'light') : 'light';
      if (theme === 'dark') document.documentElement.classList.add('dark');
    })();
  </script>

  <!-- Phosphor Icons (web, duotone) -->
  <script src="https://unpkg.com/@phosphor-icons/web@2.1.1" defer></script>

  <!-- Font preloads — PRD section 2.2 -->
  <link rel="preload" href="/fonts/IBMPlexSans-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/IBMPlexSerif-Bold.woff2" as="font" type="font/woff2" crossorigin />
</head>
<body class="bg-background text-foreground font-sans">
  <Nav />
  <main class="pt-16 scroll-canvas">
    <slot />
  </main>
  <Footer />

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { ScrollToPlugin } from 'gsap/ScrollToPlugin';

    gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

    // Gate: only run on desktop AND no reduced motion
    const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (isDesktop && !prefersReducedMotion) {
      const sections = gsap.utils.toArray<HTMLElement>('.scroll-section');
      if (sections.length > 0) {
      const navH = 64;
      const vh = window.innerHeight;

      // Single pinned container with all sections stacked.
      // One master timeline: for each transition —
      //   zoom-out → hold → slide → hold → zoom-in

      const container = sections[0].parentElement!;
      const sectionCount = sections.length;

      // Stack all sections absolutely inside the container
      container.style.position = 'relative';
      container.style.height = `${vh - navH}px`;
      container.style.overflow = 'hidden';

      sections.forEach((section, i) => {
        const el = section as HTMLElement;
        el.style.position = 'absolute';
        el.style.top = '0';
        el.style.left = '0';
        el.style.width = '100%';
        el.style.height = '100%';
        el.style.minHeight = '100%';
        if (i === 0) {
          // First section visible and active — animations can run
          el.setAttribute('data-active', '');
        } else {
          // Rest start below and inactive — animations suppressed
          gsap.set(el, { yPercent: 100 });
        }
      });

      // Build one master timeline — evenly spaced snap points
      const snapPoints: number[] = [0];
      const transDur = 1.6; // 0.5 zoom-out + 0.6 slide + 0.5 zoom-in

      // Even spacing — no breathing room, so every transition is identical
      for (let i = 1; i < sectionCount; i++) {
        snapPoints.push(i / (sectionCount - 1));
      }

      const master = gsap.timeline({
        scrollTrigger: {
          trigger: container,
          start: `top top+=${navH}`,
          end: `+=${vh * 1.2 * (sectionCount - 1)}`,
          pin: true,
          pinSpacing: true,
          scrub: true,
          anticipatePin: 1,
          snap: {
            snapTo: snapPoints,
            delay: 0,
            duration: 1.2,
            ease: 'power2.inOut',
          },
          onUpdate: (self: any) => {
            // Save current section for reload restore
            const idx = Math.round(self.progress * (sectionCount - 1));
            sessionStorage.setItem('consultates-section', String(idx));
          },
        },
      });

      // Build transitions
      for (let i = 0; i < sectionCount - 1; i++) {
        const cur = sections[i] as HTMLElement;
        const next = sections[i + 1] as HTMLElement;

        // Phase 1: Zoom OUT current — pull back to reveal canvas
        master.to(cur, {
          scale: 0.8, borderRadius: '16px',
          duration: 0.5, ease: 'power2.inOut',
        });

        // Position next card on the "paper strip" just below current
        // At 0.8 scale: card=80%, border=10% each side, gap=10%
        // Distance between card centers = 80% + 10% gap = 90%
        master.set(next, { yPercent: 90, scale: 0.8, borderRadius: '16px', opacity: 1 });

        // Phase 2: Slide both as one strip — both move up by 90%
        master.to(cur, {
          yPercent: -90,
          duration: 0.6, ease: 'power1.inOut',
        });
        master.to(next, {
          yPercent: 0,
          duration: 0.6, ease: 'power1.inOut',
        }, '<');

        // Hide outgoing card now that it's off-screen
        master.set(cur, { opacity: 0 });

        // Phase 3: Zoom IN next — push in to fill the window
        // Mark section active so Framer Motion animations can start
        master.call(() => { next.setAttribute('data-active', ''); });
        master.to(next, {
          scale: 1, borderRadius: '0px',
          duration: 0.5, ease: 'power2.inOut',
        });
      }

      // Programmatic section navigation — bypasses the scrub timeline
      // to produce a clean 3-phase jump: zoom-out → roll each frame past → zoom-in.
      //
      // Why bypass? The master timeline encodes zoom-in/zoom-out at every
      // section boundary. Scrolling through it plays every intermediate cycle.
      // We want: one pull-back, each frame rolling past at 0.8 scale, one push-in.
      //
      // We disable the ScrollTrigger with reset=false to keep the pin in place,
      // run a custom timeline, then re-enable at the correct scroll position.
      const st = master.scrollTrigger!;
      let isJumping = false;

      (window as any).scrollToSection = (targetIndex: number) => {
        if (targetIndex < 0 || targetIndex >= sectionCount || isJumping) return;

        const currentIndex = Math.round(st.progress * (sectionCount - 1));
        if (targetIndex === currentIndex) return;

        isJumping = true;
        const direction = targetIndex > currentIndex ? 1 : -1;
        const cur = sections[currentIndex] as HTMLElement;
        const dest = sections[targetIndex] as HTMLElement;
        const slideY = 90; // yPercent gap between cards at 0.8 scale

        // Disable ScrollTrigger but keep pin in place (reset=false)
        st.disable(false);

        // Build the jump animation
        const jump = gsap.timeline({
          onComplete: () => {
            // Reset all sections to the state the master timeline expects
            // at the destination snap point so scrub resumes correctly.
            sections.forEach((s, i) => {
              const el = s as HTMLElement;
              if (i === targetIndex) {
                gsap.set(el, { scale: 1, borderRadius: '0px', yPercent: 0, opacity: 1 });
              } else if (i < targetIndex) {
                // Sections before destination: off-screen above, hidden
                gsap.set(el, { scale: 1, borderRadius: '0px', yPercent: -90, opacity: 0 });
              } else {
                // Sections after destination: off-screen below, ready
                gsap.set(el, { scale: 1, borderRadius: '0px', yPercent: 100, opacity: 1 });
              }
            });

            // Sync master timeline to destination progress
            master.progress(snapPoints[targetIndex]);

            // Set scroll to the exact snap position BEFORE re-enabling
            const targetScroll = st.start + (st.end - st.start) * snapPoints[targetIndex];
            window.scrollTo(0, targetScroll);

            // Re-enable without reset or refresh (we've already positioned everything)
            st.enable(false, false);

            isJumping = false;
          },
        });

        // ── Phase 1: Zoom out current section ──
        jump.to(cur, {
          scale: 0.8, borderRadius: '16px',
          duration: 0.4, ease: 'power2.inOut',
        });

        // ── Phase 2: Roll each intermediate frame past at 0.8 scale ──
        // Each section slides in from one side and out the other, like
        // frames on a film strip winding past the projector gate.
        let prev = cur;
        const stepCount = Math.abs(targetIndex - currentIndex);
        const rollPerFrame = Math.max(0.15, Math.min(0.35, 1.0 / stepCount));

        for (let step = 1; step <= stepCount; step++) {
          const frameIndex = currentIndex + step * direction;
          const frame = sections[frameIndex] as HTMLElement;

          // Position next frame just off-screen in the scroll direction
          jump.set(frame, {
            yPercent: direction * slideY,
            scale: 0.8,
            borderRadius: '16px',
            opacity: 1,
          });

          // Slide both: previous exits, new frame enters
          jump.to(prev, {
            yPercent: -direction * slideY,
            duration: rollPerFrame,
            ease: 'none',
          });
          jump.to(frame, {
            yPercent: 0,
            duration: rollPerFrame,
            ease: 'none',
          }, '<');

          // Hide the frame that just exited
          jump.set(prev, { opacity: 0 });

          prev = frame;
        }

        // ── Phase 3: Zoom in on the destination ──
        jump.call(() => { dest.setAttribute('data-active', ''); });
        jump.to(dest, {
          scale: 1, borderRadius: '0px',
          duration: 0.4, ease: 'power2.inOut',
        });
      };

      // Check for URL section param (cross-page navigation takes priority)
      const urlSectionParam = new URLSearchParams(window.location.search).get('section');

      // Restore section on reload (skip if URL param present — cross-page nav takes priority)
      if (!urlSectionParam) {
        const savedIdx = sessionStorage.getItem('consultates-section');
        if (savedIdx) {
          const idx = parseInt(savedIdx, 10);
          if (idx > 0 && idx < sectionCount) {
            // Jump to saved section without animation
            sections.forEach((s, i) => {
              const el = s as HTMLElement;
              if (i === idx) {
                gsap.set(el, { scale: 1, borderRadius: '0px', yPercent: 0, opacity: 1 });
                el.setAttribute('data-active', '');
              } else if (i < idx) {
                gsap.set(el, { scale: 1, borderRadius: '0px', yPercent: -90, opacity: 0 });
                el.removeAttribute('data-active');
              } else {
                gsap.set(el, { scale: 1, borderRadius: '0px', yPercent: 100, opacity: 1 });
                el.removeAttribute('data-active');
              }
            });
            // First section was marked active on init — clear it if we're not on it
            if (idx !== 0) sections[0].removeAttribute('data-active');
            master.progress(snapPoints[idx]);
            const targetScroll = st.start + (st.end - st.start) * snapPoints[idx];
            window.scrollTo(0, targetScroll);
          }
        }
      }

      } // sections.length > 0 guard
    }

    // Mobile fallback: smooth-scroll to section by index (no GSAP snap on mobile)
    if (!isDesktop || prefersReducedMotion) {
      const sections = document.querySelectorAll<HTMLElement>('.scroll-section');
      if (sections.length > 0) {
        (window as any).scrollToSection = (index: number) => {
          const target = sections[index];
          if (!target) return;
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        };
      }
    }

    // URL param auto-scroll: /?section=2 scrolls to that section on load
    // Works with both desktop (GSAP) and mobile (scrollIntoView) paths
    {
      const sectionParam = new URLSearchParams(window.location.search).get('section');
      if (sectionParam !== null) {
        const sectionIndex = parseInt(sectionParam, 10);
        const allSections = document.querySelectorAll<HTMLElement>('.scroll-section');
        if (!isNaN(sectionIndex) && sectionIndex >= 0 && sectionIndex < allSections.length && (window as any).scrollToSection) {
          // Clear sessionStorage so reload doesn't fight with URL param
          sessionStorage.removeItem('consultates-section');
          // Clean up URL so param doesn't persist on reload
          history.replaceState(null, '', window.location.pathname);
          // Delay to ensure GSAP timeline is fully ready
          requestAnimationFrame(() => {
            setTimeout(() => {
              (window as any).scrollToSection(sectionIndex);
            }, 100);
          });
        }
      }
    }
  </script>
<script>
// Magnetic cursor effect for .btn-alive elements
(function() {
  const PULL = 4; // max px shift toward cursor
  const THRESHOLD = 80; // activation distance in px
  document.querySelectorAll('.btn-alive').forEach(function(btn) {
    btn.addEventListener('mousemove', function(e) {
      var rect = btn.getBoundingClientRect();
      var cx = rect.left + rect.width / 2;
      var cy = rect.top + rect.height / 2;
      var dx = (e.clientX - cx) / (THRESHOLD) * PULL;
      var dy = (e.clientY - cy) / (THRESHOLD) * PULL;
      dx = Math.max(-PULL, Math.min(PULL, dx));
      dy = Math.max(-PULL, Math.min(PULL, dy));
      btn.style.transform = 'translate(' + dx + 'px,' + dy + 'px) translateY(-2px)';
    });
    btn.addEventListener('mouseleave', function() {
      btn.style.transform = '';
    });
  });
})();
</script>
</body>
</html>
