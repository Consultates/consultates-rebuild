---
import Base from '../../layouts/Base.astro';
import { SectionAnimator } from '../../components/islands/SectionAnimator';
import { StakesCTAPulse } from '../../components/islands/StakesCTAPulse';
import { TIDYCAL_URL } from '../../config';

const sectionPadding = 'padding: clamp(4rem, 8vw, 8rem) clamp(1.5rem, 5vw, 8rem);';

const outcomes = [
  {
    title: 'Built on real work',
    desc: "Every workshop is built around your team's actual tasks — the tools they'll use tomorrow, the problems they're dealing with today.",
  },
  {
    title: 'Learn by doing',
    desc: "People learn by doing, not by watching slides. Your team practises with AI on their actual tasks, not hypothetical examples.",
  },
  {
    title: 'Behavioural change, not certificates',
    desc: "Gary tracks daily tool usage and behavioural change, not completion rates. The goal is adoption, not attendance.",
  },
  {
    title: 'Production experience',
    desc: "The curriculum comes from building production systems, not reading about them.",
  },
];

const scenarios = [
  'Teams told to "use AI" but given no guidance',
  'Sales, marketing, and operations teams doing knowledge work',
  'Groups of 5 to 50 people',
];
---

<Base title="AI Training for Teams — Consultates" description="Hands-on AI workshops built around your team's actual work. Design thinking approach — people learn by doing.">

  <!-- Hero: left-aligned with stat callout -->
  <section style={sectionPadding}>
    <div style="max-width: 1200px; margin: 0 auto;">
      <SectionAnimator client:visible>
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-12 items-center">
          <div>
            <h1 class="text-hero">AI Training for Teams</h1>
            <p class="text-body-lg text-muted-foreground mt-4">
              Hands-on workshops built around your team's actual work. Design thinking approach — people learn by doing.
            </p>
          </div>
          <div style={`
            background: var(--secondary);
            border-radius: var(--card-radius);
            padding: var(--card-padding);
            text-align: center;
          `}>
            <span class="font-serif font-bold" style="font-size: clamp(2rem, 4vw, 3rem); color: var(--primary); display: block;">30–50</span>
            <span class="text-caption text-muted-foreground mt-2" style="display: block;">person cohorts trained</span>
          </div>
        </div>
      </SectionAnimator>
    </div>
  </section>

  <!-- What You Get: 2x2 icon grid -->
  <section style={sectionPadding}>
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 class="text-section mb-8">What you get</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" style="max-width: 900px;">
        {outcomes.map((item, i) => (
          <SectionAnimator client:visible delay={i * 0.1}>
            <div style={`
              background: var(--card);
              border-radius: var(--card-radius);
              padding: var(--card-padding);
              border: 1px solid var(--border);
            `}>
              <div style={`
                width: 40px; height: 40px; border-radius: 50%;
                background: color-mix(in srgb, var(--primary) 10%, transparent);
                margin-bottom: 1rem;
              `}></div>
              <h3 class="text-sub font-serif mb-2">{item.title}</h3>
              <p class="text-body text-muted-foreground">{item.desc}</p>
            </div>
          </SectionAnimator>
        ))}
      </div>
    </div>
  </section>

  <!-- Who It's For: bordered scenario list -->
  <section style={sectionPadding}>
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 class="text-section mb-8">Who it's for</h2>
      <SectionAnimator client:visible>
        <div style={`
          border-left: 4px solid var(--primary);
          background: var(--card);
          border-radius: var(--card-radius);
          padding: var(--card-padding);
          max-width: 700px;
        `}>
          <ul class="space-y-3" style="list-style: disc; padding-left: 1.25rem;">
            {scenarios.map((s) => (
              <li class="text-body text-muted-foreground">{s}</li>
            ))}
          </ul>
        </div>
      </SectionAnimator>
    </div>
  </section>

  <!-- Testimonial: white bg with top border -->
  <section style={`${sectionPadding} border-top: 1px solid var(--border);`}>
    <div style="max-width: 1200px; margin: 0 auto;">
      <SectionAnimator client:visible>
        <div style="max-width: 700px; margin: 0 auto;">
          <blockquote class="text-body-lg" style="font-style: italic;">
            The workshop transformed how our team thinks about AI. Within a week, three departments had built their own automations.
          </blockquote>
          <div style="display: flex; align-items: center; gap: 1rem; margin-top: 1.5rem;">
            <div style={`
              width: 72px; height: 72px; border-radius: 50%; flex-shrink: 0;
              background: color-mix(in srgb, var(--primary) 10%, transparent);
              display: flex; align-items: center; justify-content: center;
            `}>
              <span class="text-primary font-serif" style="font-size: 1.25rem; font-weight: 600;">KL</span>
            </div>
            <div>
              <p class="text-body" style="font-weight: 600;">Head of Operations</p>
              <p class="text-caption text-muted-foreground">Technology Company</p>
            </div>
          </div>
        </div>
      </SectionAnimator>
    </div>
  </section>

  <!-- How It Works: connecting line -->
  <section style={sectionPadding}>
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 class="text-section mb-12">How it works</h2>
      <div class="hiw-steps">
        <SectionAnimator client:visible delay={0}>
          <div class="hiw-step">
            <div class="hiw-node">1</div>
            <div class="hiw-content">
              <h3 class="text-sub font-serif mb-2">We talk</h3>
              <p class="text-body text-muted-foreground">Tell me where you are and what you're trying to figure out. No preparation needed.</p>
            </div>
          </div>
        </SectionAnimator>
        <SectionAnimator client:visible delay={0.15}>
          <div class="hiw-step">
            <div class="hiw-node">2</div>
            <div class="hiw-content">
              <h3 class="text-sub font-serif mb-2">You get a plan</h3>
              <p class="text-body text-muted-foreground">Specific to your business, your team, and your goals. Not a template.</p>
            </div>
          </div>
        </SectionAnimator>
        <SectionAnimator client:visible delay={0.3}>
          <div class="hiw-step">
            <div class="hiw-node">3</div>
            <div class="hiw-content">
              <h3 class="text-sub font-serif mb-2">Your team ships</h3>
              <p class="text-body text-muted-foreground">Within days, your team is building automations on their actual work. Measured by adoption, not attendance.</p>
            </div>
          </div>
        </SectionAnimator>
      </div>
    </div>
  </section>

  <!-- Dark CTA -->
  <section style="background: #0D1117;">
    <div class="glow corner-marks max-w-[800px] mx-auto text-center"
         style="padding: clamp(4rem, 8vw, 8rem) clamp(1.5rem, 5vw, 8rem); --corner-color: rgba(139,108,199,0.4);">
      <SectionAnimator client:visible>
        <h2 class="text-section" style="color: #FFFFFF;">
          Ready to <em style="font-style: normal; color: #8B6CC7;">upskill</em> your team?
        </h2>
      </SectionAnimator>
      <div class="mt-8">
        <StakesCTAPulse client:visible href={TIDYCAL_URL} text="Book a Free Call" />
      </div>
    </div>
  </section>
</Base>

<style>
  .hiw-steps {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .hiw-steps::before {
    content: '';
    position: absolute;
    left: 23px;
    top: 24px;
    bottom: 24px;
    width: 2px;
    background: var(--border);
  }

  .hiw-step {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    position: relative;
  }

  .hiw-node {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid var(--primary);
    background: var(--background);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--primary);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .hiw-content {
    padding-top: 0.5rem;
  }

  @media (min-width: 768px) {
    .hiw-steps {
      flex-direction: row;
      gap: 2rem;
    }

    .hiw-steps::before {
      left: 24px;
      right: 24px;
      top: 23px;
      bottom: auto;
      width: auto;
      height: 2px;
    }

    .hiw-step {
      flex-direction: column;
      align-items: center;
      text-align: center;
      flex: 1;
    }

    .hiw-content {
      padding-top: 0;
    }
  }
</style>
