---
import Base from '../../layouts/Base.astro';
import SocialProofIsland from '../../components/islands/SocialProofIsland';
import { HowItWorksIsland } from '../../components/islands/HowItWorksIsland';
import { StakesCTAPulse } from '../../components/islands/StakesCTAPulse';
import { StaggerHeading } from '../../components/islands/StaggerHeading';
import { TIDYCAL_URL } from '../../config';
import { fractionalTestimonials } from '../../data/social-proof';

const outcomes = [
  {
    icon: 'ph-map-trifold',
    title: 'GTM Strategy',
    desc: 'Building your go-to-market motion from zero across new markets and verticals',
  },
  {
    icon: 'ph-compass',
    title: 'Product Direction',
    desc: 'Shaping product direction with hands-on leadership, not advisory from a distance',
  },
  {
    icon: 'ph-globe-hemisphere-west',
    title: 'Team & Network',
    desc: 'Advising your team and opening doors through a global network built across five continents',
  },
];

const whoItsFor = [
  {
    label: 'AI startups & scale-ups',
    desc: 'Need experienced GTM leadership for AI products without a full-time hire',
  },
  {
    label: 'New market entry',
    desc: 'Companies launching AI products or entering new markets and verticals',
  },
  {
    label: 'Flex over fixed',
    desc: "Not ready for (or don't need) a full-time exec hire — need senior leadership on demand",
  },
];
---

<Base title="Fractional Executive Support — Consultates" description="Senior AI go-to-market leadership without a full-time hire. Strategy, product direction, and execution.">

  <!-- Hero: dark -->
  <section class="svc-hero bg-dots">
    <div class="svc-hero__glow"></div>
    <div class="svc-hero__content">
      <h1 class="text-hero font-serif" style="color: #FFFFFF; max-width: 820px; margin: 0 auto;">Fractional Executive Support</h1>
      <p class="text-body-lg mt-4" style="color: var(--hero-muted); max-width: 600px; margin: 0 auto;">
        Senior AI go-to-market leadership without a full-time hire.
      </p>
    </div>
  </section>

  <!-- What You Get -->
  <section class="svc-section">
    <div class="svc-container">
      <h2 class="text-section mb-8">What you get</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>
        {outcomes.map((item) => (
          <div class="svc-card" data-reveal>
            <div class="svc-icon-circle">
              <i class={`ph-duotone ${item.icon}`}></i>
            </div>
            <h3 class="text-sub font-serif mb-2">{item.title}</h3>
            <p class="text-body text-muted-foreground">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="svc-section bg-secondary">
    <div class="svc-container">
      <h2 class="text-section mb-8">Who it's for</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>
        {whoItsFor.map((item) => (
          <div class="svc-card svc-card--flat" data-reveal>
            <h3 class="text-sub font-serif mb-2">{item.label}</h3>
            <p class="text-body text-muted-foreground">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials: carousel -->
  <section class="svc-section">
    <div class="svc-container">
      <h2 class="text-section mb-10">What clients say</h2>
      <SocialProofIsland client:visible quotes={fractionalTestimonials} />
    </div>
  </section>

  <!-- How It Works -->
  <section class="svc-section bg-secondary">
    <div class="svc-container">
      <h2 class="text-section mb-12">How it works</h2>
      <HowItWorksIsland
        client:visible
        steps={[
          { number: '01', title: 'We talk', description: 'Tell me where you are and what you\'re trying to figure out. No preparation needed.' },
          { number: '02', title: 'You get a plan', description: 'Specific to your business, your market, and your goals. Not a template.' },
          { number: '03', title: 'We scale together', description: 'Hands-on leadership building your GTM motion, coaching your team, and opening doors.' },
        ]}
        showCta={false}
      />
    </div>
  </section>

  <!-- Dark CTA -->
  <section style="background: #0D1117;">
    <div class="glow corner-marks max-w-[800px] mx-auto text-center"
         style="padding: clamp(4rem, 8vw, 8rem) clamp(1.5rem, 5vw, 8rem); --corner-color: rgba(139,108,199,0.4);">
      <StaggerHeading client:visible text="Ready for <em>experienced</em> leadership?" className="text-section" style={{ color: '#FFFFFF' }} />
      <div class="mt-8">
        <StakesCTAPulse client:visible href={TIDYCAL_URL} text="Book a Free Call" />
      </div>
    </div>
  </section>
</Base>

<style>
  .svc-hero {
    background: var(--hero-bg, #0D1117);
    position: relative;
    overflow: hidden;
    min-height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(6rem, 14vw, 10rem) var(--content-px) clamp(4rem, 8vw, 6rem);
  }

  .svc-hero::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 700px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(92,59,156,0.20) 0%, rgba(92,59,156,0.08) 40%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  .svc-hero__glow {
    position: absolute;
    inset: 0;
    background: var(--hero-bg, #0D1117);
    opacity: 0.5;
    pointer-events: none;
  }

  .svc-hero__content {
    position: relative;
    z-index: 2;
    max-width: var(--content-max, 1140px);
    width: 100%;
    text-align: center;
  }

  .svc-section {
    padding: clamp(4rem, 8vw, 8rem) var(--content-px);
  }

  .svc-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .svc-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--card-radius);
    padding: var(--card-padding);
    border-top: 3px solid var(--primary);
  }

  .svc-card--flat {
    border-top: 1px solid var(--border);
    background: var(--card);
  }

  .svc-icon-circle {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--secondary);
    border: 2px solid var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: var(--primary);
    margin-bottom: 1rem;
  }


  [data-reveal] {
    opacity: 0;
    transition: opacity 0.6s ease-out;
  }

  [data-reveal].is-visible {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transition: none;
    }
  }
</style>

<script>
  requestAnimationFrame(() => {
    const items = document.querySelectorAll('[data-reveal]');
    if (!items.length) return;
    let staggerIndex = 0;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = staggerIndex * 150;
            staggerIndex++;
            setTimeout(() => el.classList.add('is-visible'), delay);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.15 }
    );
    items.forEach((item) => observer.observe(item));
  });
</script>
