---
import Base from '../../layouts/Base.astro';
import SocialProofIsland from '../../components/islands/SocialProofIsland';
import { HowItWorksIsland } from '../../components/islands/HowItWorksIsland';
import { StakesCTAPulse } from '../../components/islands/StakesCTAPulse';
import { StaggerHeading } from '../../components/islands/StaggerHeading';
import { TIDYCAL_URL } from '../../config';
import { advisoryTestimonials } from '../../data/social-proof';

const outcomes = [
  {
    icon: 'ph-shield-check',
    title: 'A confidential sounding board',
    desc: "Gary has sat across from C-suite executives for 15 years. The coaching isn't theoretical — it comes from someone who builds with AI every day.",
  },
  {
    icon: 'ph-crosshair',
    title: 'Your situation, your agenda',
    desc: "Each session starts with where you are right now. What you're trying to figure out. What's keeping you up at night about AI.",
  },
  {
    icon: 'ph-list-checks',
    title: "Specific next steps, not general advice",
    desc: "You leave with actionable steps you can implement immediately. No fixed curriculum — the agenda is your situation.",
  },
];

const scenarios = [
  {
    label: 'Business Leaders',
    desc: "You're running a company and need clarity on AI without the jargon",
  },
  {
    label: 'Founders & Solopreneurs',
    desc: "You're building something and want to use AI as a force multiplier",
  },
  {
    label: 'Consultants & Fractionals',
    desc: 'You advise others and need to stay ahead of the curve',
  },
];
---

<Base title="AI Advisory for Leaders — Consultates" description="One-to-one AI advisory sessions for business leaders. You bring your situation, you leave with a plan you can act on.">

  <!-- Hero: dark -->
  <section class="svc-hero bg-dots">
    <div class="svc-hero__glow"></div>
    <div class="svc-hero__content">
      <h1 class="text-hero font-serif" style="color: #FFFFFF; max-width: 820px; margin: 0 auto;">AI Advisory for Leaders</h1>
      <p class="text-body-lg mt-4" style="color: var(--hero-muted); max-width: 600px; margin: 0 auto;">
        One-to-one sessions. You bring your real situation — you leave with a plan you can act on.
      </p>
    </div>
  </section>

  <!-- What You Get -->
  <section class="svc-section">
    <div class="svc-container">
      <h2 class="text-section mb-8">What you get</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>
        {outcomes.map((item) => (
          <div class="svc-card" data-reveal>
            <div class="svc-icon-circle">
              <i class={`ph-duotone ${item.icon}`}></i>
            </div>
            <h3 class="text-sub font-serif mb-2">{item.title}</h3>
            <p class="text-body text-muted-foreground">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="svc-section bg-secondary">
    <div class="svc-container">
      <h2 class="text-section mb-8">Who it's for</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>
        {scenarios.map((s) => (
          <div class="svc-card svc-card--flat" data-reveal>
            <h3 class="text-sub font-serif mb-2">{s.label}</h3>
            <p class="text-body text-muted-foreground">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials: carousel -->
  <section class="svc-section">
    <div class="svc-container">
      <h2 class="text-section mb-10">What clients say</h2>
      <SocialProofIsland client:visible quotes={advisoryTestimonials} />
    </div>
  </section>

  <!-- How It Works -->
  <section class="svc-section bg-secondary">
    <div class="svc-container">
      <h2 class="text-section mb-12">How it works</h2>
      <HowItWorksIsland
        client:visible
        steps={[
          { number: '01', title: 'We talk', description: 'Tell me where you are and what you\'re trying to figure out. No preparation needed.' },
          { number: '02', title: 'You get a plan', description: 'Specific to your business, your team, and your goals. Not a template.' },
          { number: '03', title: 'You act', description: 'You leave with specific next steps you can implement immediately — not a deck, a plan.' },
        ]}
        showCta={false}
      />
    </div>
  </section>

  <!-- Dark CTA -->
  <section style="background: #0D1117;">
    <div class="glow corner-marks max-w-[800px] mx-auto text-center"
         style="padding: clamp(4rem, 8vw, 8rem) clamp(1.5rem, 5vw, 8rem); --corner-color: rgba(139,108,199,0.4);">
      <StaggerHeading client:visible text="Ready for <em>clarity</em> on AI?" className="text-section" style={{ color: '#FFFFFF' }} />
      <div class="mt-8">
        <StakesCTAPulse client:visible href={TIDYCAL_URL} text="Book a Free Call" />
      </div>
    </div>
  </section>
</Base>

<style>
  .svc-hero {
    background: var(--hero-bg, #0D1117);
    position: relative;
    overflow: hidden;
    min-height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(6rem, 14vw, 10rem) var(--content-px) clamp(4rem, 8vw, 6rem);
  }

  .svc-hero::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 700px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(92,59,156,0.20) 0%, rgba(92,59,156,0.08) 40%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  .svc-hero__glow {
    position: absolute;
    inset: 0;
    background: var(--hero-bg, #0D1117);
    opacity: 0.5;
    pointer-events: none;
  }

  .svc-hero__content {
    position: relative;
    z-index: 2;
    max-width: var(--content-max, 1140px);
    width: 100%;
    text-align: center;
  }

  .svc-section {
    padding: clamp(4rem, 8vw, 8rem) var(--content-px);
  }

  .svc-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .svc-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--card-radius);
    padding: var(--card-padding);
    border-top: 3px solid var(--primary);
  }

  .svc-card--flat {
    border-top: 1px solid var(--border);
    background: var(--card);
  }

  .svc-icon-circle {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--secondary);
    border: 2px solid var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: var(--primary);
    margin-bottom: 1rem;
  }


  [data-reveal] {
    opacity: 0;
    transition: opacity 0.6s ease-out;
  }

  [data-reveal].is-visible {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transition: none;
    }
  }
</style>

<script>
  requestAnimationFrame(() => {
    const items = document.querySelectorAll('[data-reveal]');
    if (!items.length) return;
    let staggerIndex = 0;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = staggerIndex * 150;
            staggerIndex++;
            setTimeout(() => el.classList.add('is-visible'), delay);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.15 }
    );
    items.forEach((item) => observer.observe(item));
  });
</script>
