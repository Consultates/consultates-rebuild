---
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
---

<Base title="Page Not Found — Consultates">
  <section class="min-h-[60vh] flex flex-col items-center justify-center text-center p-8">
    <h1 class="text-hero">Page not found</h1>
    <p class="text-body-lg text-muted-foreground mt-4">The page you're looking for doesn't exist or has been moved.</p>
    <div class="mt-8">
      <Button variant="secondary" href="/">Back to Home</Button>
    </div>
  </section>
</Base>
