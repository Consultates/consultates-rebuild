---
import Base from '../layouts/Base.astro';
import FormInput from '../components/FormInput.astro';
import Button from '../components/Button.astro';
import { TIDYCAL_URL, EMAIL, LINKEDIN_URL } from '../config';
---

<Base title="Contact — Consultates" description="Get in touch with Gary Tate. Book a free call, send a message, or connect on LinkedIn.">

  <section style="padding: clamp(4rem, 8vw, 8rem) clamp(1.5rem, 5vw, 8rem);">
    <div style="max-width: 1200px; margin: 0 auto;" class="grid grid-cols-1 md:grid-cols-2 gap-12">

      <!-- Left column -->
      <div>
        <h1 class="text-section mb-6">Let's talk</h1>
        <p class="text-body-lg text-muted-foreground mb-8">Whether you have a specific challenge or just want to explore how AI fits into your business — I'd like to hear from you. Book a call, send a message, or connect on LinkedIn.</p>
        <ul class="text-body space-y-2">
          <li>
            <span>Email: </span>
            <a href={`mailto:${EMAIL}`} class="underline hover:text-primary">{EMAIL}</a>
          </li>
          <li>
            <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" class="underline hover:text-primary">LinkedIn</a>
          </li>
          <li>
            <a href={TIDYCAL_URL} target="_blank" rel="noopener noreferrer" class="underline hover:text-primary">Book a free call</a>
          </li>
        </ul>
      </div>

      <!-- Right column — Contact form -->
      <div>
        <form id="contact-form" class="space-y-4">
          <FormInput label="Name" name="name" required={true} placeholder="Your name" />
          <FormInput label="Email" name="email" type="email" required={true} placeholder="you@example.com" />
          <FormInput label="Company" name="company" placeholder="Your company (optional)" />
          <FormInput label="Message" name="message" textarea={true} required={true} placeholder="How can I help?" />

          <!-- Honeypot -->
          <input type="text" name="website" class="sr-only" tabindex="-1" autocomplete="off" />

          <Button variant="primary" type="submit">Send Message</Button>
        </form>

        <div
          id="contact-success"
          style="display: none; background: var(--secondary); border: 1px solid var(--border); border-radius: 0.75rem; padding: 1rem; color: var(--foreground);"
        >
          Thanks for your message. I'll get back to you within 24 hours.
        </div>
      </div>

    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const success = document.getElementById('contact-success');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();

      // Check honeypot
      const honeypot = form.querySelector('input[name="website"]') as HTMLInputElement | null;
      if (honeypot?.value) return;

      // Basic validation
      const name = form.querySelector('input[name="name"]') as HTMLInputElement | null;
      const email = form.querySelector('input[name="email"]') as HTMLInputElement | null;
      const message = form.querySelector('textarea[name="message"]') as HTMLTextAreaElement | null;

      if (!name || name.value.length < 2 || name.value.length > 100) return;
      if (!email || !email.validity.valid) return;
      if (!message || message.value.length < 10 || message.value.length > 5000) return;

      // Disable submit, show sending
      const btn = form.querySelector('button[type="submit"]');
      if (btn) {
        (btn as HTMLButtonElement).disabled = true;
        btn.textContent = 'Sending...';
      }

      // After 1s, hide form, show success
      setTimeout(() => {
        form.style.display = 'none';
        if (success) success.style.display = 'block';
      }, 1000);
    });
  </script>

</Base>
