---
import Base from '../layouts/Base.astro';
import FormInput from '../components/FormInput.astro';
import ContactHeroIsland from '../components/islands/ContactHeroIsland.tsx';
import { EMAIL, RECAPTCHA_SITE_KEY, CONTACT_FORM_URL } from '../config';
---

<Base title="Contact — Consultates" description="Get in touch with Gary Tate. Book a free call, send a message, or connect on LinkedIn.">

  <!-- Dark hero — mirrors HeroSection.astro styling -->
  <section class="c-contact-hero">
    <div class="c-contact-hero-content">
      <ContactHeroIsland
        client:load
        headline="Let's <em>talk</em>"
        paragraph="Whether you have a specific challenge or just want to explore how AI fits into your business — I'd like to hear from you."
        ctaText="Book a Free Call"
      />
    </div>
  </section>

  <!-- TidyCal embed — revealed on hover/click/2s timer, pushes form down -->
  <div id="tidycal-panel" style="display: none; background: var(--background); padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 5vw, 8rem);">
    <div style="max-width: 1200px; margin: 0 auto;" id="tidycal-inner">
    </div>
  </div>

  <!-- Contact form on cream — hidden until hero animation completes -->
  <section id="contact-form-section" style="opacity: 0; background: var(--secondary); padding: clamp(3rem, 6vw, 5rem) clamp(1.5rem, 5vw, 8rem);">
    <div style="max-width: 1200px; margin: 0 auto;">

      <form id="contact-form">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Left column -->
          <div class="space-y-4">
            <FormInput label="Name" name="name" required={true} placeholder="Your name" icon="user" />
            <FormInput label="Email" name="email" type="email" required={true} placeholder="you@example.com" icon="envelope" />
          </div>
          <!-- Right column -->
          <div class="space-y-4">
            <FormInput label="Company" name="company" placeholder="Your company (optional)" icon="buildings" />
            <FormInput label="Message" name="message" textarea={true} rows={3} required={true} placeholder="How can I help?" icon="note" />
            <!-- Honeypot -->
            <input type="text" name="website" class="sr-only" tabindex="-1" autocomplete="off" />
            <div class="mt-4">
              <button type="submit" class="btn-alive btn-alive--sm">
                Send Message
              </button>
            </div>
          </div>
        </div>
      </form>

      <div
        id="contact-success"
        style="display: none; background: var(--card); border: 1px solid var(--border); border-radius: var(--card-radius, 16px); padding: 1.5rem; color: var(--foreground);"
        class="mt-6"
      >
        Thanks for your message. I'll get back to you within 24 hours.
      </div>

      <p
        id="contact-error"
        style="display: none; color: var(--destructive);"
        class="text-caption mt-4"
      >
        Something went wrong. Please try again or email <a href={`mailto:${EMAIL}`} class="underline">{EMAIL}</a> directly.
      </p>

    </div>
  </section>

  <script is:inline defer src={`https://www.google.com/recaptcha/api.js?render=${RECAPTCHA_SITE_KEY}`}></script>

  <script define:vars={{ RECAPTCHA_SITE_KEY, CONTACT_FORM_URL }}>
    // --- Form section reveal (triggered by ContactHeroIsland onComplete) ---
    // The React island dispatches a custom event when the hero animation finishes.
    // We listen for it here to fade in the form section.
    const formSection = document.getElementById('contact-form-section');

    function revealForm() {
      if (!formSection) return;
      formSection.style.transition = 'opacity 0.6s ease';
      formSection.style.opacity = '1';
    }

    // Also reveal form after a max wait (safety net if onComplete doesn't fire)
    const maxWaitTimer = setTimeout(revealForm, 5000);

    window.addEventListener('contact-hero-complete', () => {
      clearTimeout(maxWaitTimer);
      revealForm();
    });

    // --- Contact form submission ---
    const form = document.getElementById('contact-form');
    const success = document.getElementById('contact-success');
    const error = document.getElementById('contact-error');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (error) error.style.display = 'none';

      const honeypot = form.querySelector('input[name="website"]');
      if (honeypot?.value) return;

      const name = form.querySelector('input[name="name"]');
      const email = form.querySelector('input[name="email"]');
      const message = form.querySelector('textarea[name="message"]');

      if (!name || name.value.length < 2 || name.value.length > 100) return;
      if (!email || !email.validity.valid) return;
      if (!message || message.value.length < 10 || message.value.length > 5000) return;

      const btn = form.querySelector('button[type="submit"]');
      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Sending...';
      }

      try {
        const token = await grecaptcha.execute(RECAPTCHA_SITE_KEY, { action: 'contact' });

        const response = await fetch(CONTACT_FORM_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain' },
          body: JSON.stringify({
            name: name.value.trim(),
            email: email.value.trim(),
            company: form.querySelector('input[name="company"]')?.value.trim() || '',
            message: message.value.trim(),
            website: honeypot?.value || '',
            recaptchaToken: token,
          }),
        });

        const result = await response.json();

        if (result.success) {
          form.style.display = 'none';
          if (success) success.style.display = 'block';
        } else {
          if (error) {
            error.textContent = result.error || 'Something went wrong. Please try again or email gary@consultates.com directly.';
            error.style.display = 'block';
          }
          if (btn) {
            btn.disabled = false;
            btn.textContent = 'Send Message';
          }
        }
      } catch (_) {
        if (error) error.style.display = 'block';
        if (btn) {
          btn.disabled = false;
          btn.textContent = 'Send Message';
        }
      }
    });

    // --- TidyCal — show on click, hover over CTA, or 2s after page load ---
    const bookBtn = document.getElementById('book-call-btn');
    const panelEl = document.getElementById('tidycal-panel');
    const panelInner = document.getElementById('tidycal-inner');
    let tidycalLoaded = false;

    function loadTidyCal() {
      if (tidycalLoaded || !panelEl || !panelInner) return;
      tidycalLoaded = true;
      panelEl.style.display = 'block';
      const embed = document.createElement('div');
      embed.className = 'tidycal-embed';
      embed.setAttribute('data-path', 'garyctate/15-minute-meeting');
      panelInner.appendChild(embed);
      const script = document.createElement('script');
      script.src = 'https://tidycal.com/js/embed.js';
      panelInner.appendChild(script);
    }

    if (bookBtn) {
      bookBtn.addEventListener('mouseenter', loadTidyCal);
      bookBtn.addEventListener('click', loadTidyCal);
    }

    // Load TidyCal 2s after hero animation completes (so user sees form first)
    window.addEventListener('contact-hero-complete', () => {
      setTimeout(loadTidyCal, 2000);
    });
  </script>

</Base>

<style>
  /* Contact hero — mirrors HeroSection.astro but without video */
  .c-contact-hero {
    background: var(--hero-bg, #0D1117);
    color: var(--hero-fg, #E2E0EC);
    padding: clamp(4rem, 8vw, 8rem) 0;
    text-align: center;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Radial purple glow */
  .c-contact-hero::before {
    content: '';
    position: absolute;
    top: 40%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(92,59,156,0.25) 0%, rgba(92,59,156,0.10) 40%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  /* Dot grid */
  .c-contact-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(139,108,199,0.18) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
    z-index: 1;
  }

  .c-contact-hero-content {
    position: relative;
    z-index: 2;
    max-width: var(--content-max, 1140px);
    margin: 0 auto;
    padding-left: var(--content-px, clamp(1.5rem, 4vw, 2.5rem));
    padding-right: var(--content-px, clamp(1.5rem, 4vw, 2.5rem));
  }

  /* Global styles reaching into React island — same as HeroSection.astro */
  :global(.c-hero-h1) {
    font-family: var(--font-serif);
    font-size: var(--text-hero, clamp(2.75rem, 5.5vw, 4rem));
    line-height: 1.08;
    letter-spacing: -0.025em;
    font-weight: 700;
    color: #FFFFFF;
    max-width: 820px;
    margin: 0 auto 1.75rem;
  }

  :global(.c-hero-h1 em) {
    font-style: normal;
    color: var(--stakes-accent, #8B6CC7);
  }

  :global(.c-hero-body) {
    font-size: var(--text-body-lg, clamp(1.0625rem, 1.5vw, 1.25rem));
    line-height: 1.65;
    color: var(--hero-muted, #7A7B90);
    max-width: 580px;
    margin: 0 auto 2.75rem;
  }

  :global(.c-hero-cta) {
    gap: 0.625rem;
  }
</style>
