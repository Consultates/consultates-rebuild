---
/**
 * Trust bar — absolute-positioned overlay at the bottom of each scroll-section.
 * Credential markers with dot separators, v2 design system styling.
 * Placed inside scroll-sections just below the scroll indicator.
 */
---

<div class="c-trust-overlay">
  <span class="c-trust-item">35 years across engineering, sales &amp; AI</span>
  <span class="c-trust-dot"></span>
  <span class="c-trust-item">AI-driven executive</span>
  <span class="c-trust-dot"></span>
  <span class="c-trust-item">Trains executive cohorts via Agnetics</span>
</div>

<style>
  .c-trust-overlay {
    position: absolute;
    bottom: 0.25rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    font-weight: 500;
    letter-spacing: 0.01em;
    white-space: nowrap;
    opacity: 0.5;
    z-index: 2;
    padding: 0 1rem;
  }
  .c-trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .c-trust-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--border);
    flex-shrink: 0;
  }
  /* Hide on small screens where it would wrap badly */
  @media (max-width: 1023px) {
    .c-trust-overlay {
      display: none;
    }
  }
</style>
