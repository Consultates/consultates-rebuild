---
/**
 * Social Proof section — homepage.
 * Logo ticker on cream (bg-secondary) + film-strip quote carousel on white (bg-background).
 */
import LogoTicker from '../LogoTicker.astro';
import SocialProofIsland from '../islands/SocialProofIsland';
---

<section id="section-proof">
  {/* Logo ticker — cream background */}
  <div class="bg-secondary" style="padding: clamp(1rem, 2vw, 1.5rem) 0;">
    <LogoTicker />
  </div>

  {/* Quote carousel — white background */}
  <div class="bg-background" style="padding: clamp(1.5rem, 4vh, 5rem) clamp(1.5rem, 5vw, 8rem);">
    <SocialProofIsland client:visible />
  </div>
</section>
