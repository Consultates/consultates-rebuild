---
import { SectionAnimator } from '../islands/SectionAnimator';
import OfferingCardsIsland from '../islands/OfferingCardsIsland';
---

<section
  id="section-offering"
  class="offering-section"
>
  <div class="max-w-[1200px] mx-auto" style="padding: 0 clamp(1.5rem, 5vw, 8rem);">
    <SectionAnimator client:visible delay={0.5}>
      <div class="text-center" style="margin-bottom: clamp(1.5rem, 4vh, 3.5rem);">
        <h2 class="text-section text-foreground mb-4">Three ways we help</h2>
        <p class="text-body-lg mx-auto" style="max-width: 580px; color: var(--secondary-foreground);">
          Whether you're a leader who needs clarity, a team that needs skills, or a company that needs senior AI leadership — we work with you directly. No templates. No generic workshops.
        </p>
      </div>
    </SectionAnimator>

    <OfferingCardsIsland client:visible />
  </div>
</section>

<style>
  .offering-section {
    padding: var(--section-py) 0;
    background: var(--secondary);
    position: relative;
  }

  /* Subtle top/bottom border to separate from adjacent white sections */
  .offering-section::before,
  .offering-section::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border) 20%, var(--border) 80%, transparent);
  }
  .offering-section::before { top: 0; }
  .offering-section::after { bottom: 0; }
</style>
