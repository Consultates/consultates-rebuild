---
import { SectionAnimator } from '../islands/SectionAnimator';
import { StakesCTAPulse } from '../islands/StakesCTAPulse';
---

<section id="section-cta" style="background: #0D1117;">
  <div class="glow corner-marks max-w-[800px] mx-auto text-center" style="padding: clamp(4rem, 8vw, 8rem) clamp(1.5rem, 5vw, 8rem); --corner-color: rgba(139,108,199,0.4);">
    <SectionAnimator client:visible>
      <h2 class="text-section" style="color: #FFFFFF;">
        <em style="font-style: normal; color: #8B6CC7;">84%</em> of people haven't started. The <em style="font-style: normal; color: #8B6CC7;">0.04%</em> who build with AI agents aren't waiting for you to catch up.
      </h2>
    </SectionAnimator>
    <div class="mt-8">
      <StakesCTAPulse
        client:visible
        href="https://tidycal.com/garyctate/15-minute-meeting"
        text="Book a Free Call"
      />
    </div>
  </div>
</section>
