---
import { StaggerHeading } from '../islands/StaggerHeading';
import { StakesCTAPulse } from '../islands/StakesCTAPulse';
---

<section id="section-cta" style="background: #0D1117;">
  <div class="glow corner-marks max-w-[960px] mx-auto text-center" style="padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 5vw, 8rem); --corner-color: rgba(139,108,199,0.4);">
    <StaggerHeading client:visible text="<em>84%</em> of people haven't started. The <em>0.04%</em> who build with AI agents aren't waiting for you to catch up." className="text-section" style={{ color: '#FFFFFF' }} />
    <div class="mt-4">
      <StakesCTAPulse
        client:visible
        href="https://tidycal.com/garyctate/15-minute-meeting"
        text="Book a Free Call"
      />
    </div>
  </div>
</section>
