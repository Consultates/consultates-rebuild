---
import { StaggerHeading } from '../islands/StaggerHeading';
import { StakesCTAPulse } from '../islands/StakesCTAPulse';
---

<section id="section-cta" class="bg-dots-dark" style="background: #0D1117; position: relative; overflow: hidden;">
  <div class="glow corner-marks max-w-[960px] mx-auto text-center" style="padding: clamp(3rem, 6vw, 5rem) clamp(1.5rem, 5vw, 8rem); --corner-color: rgba(139,108,199,0.4);">
    <StaggerHeading client:visible text="<em>84%</em> of people haven't started. The <em>0.04%</em> who build with AI agents aren't waiting for you to catch up." className="text-section" style={{ color: '#FFFFFF' }} />
    <p style="color: rgba(255,255,255,0.7); font-family: var(--font-sans); font-size: var(--text-body); line-height: var(--lh-body); max-width: 520px; margin: 1rem auto 0;">A 15-minute call. No pitch, no commitment. Just clarity on where AI fits in your business.</p>
    <div class="mt-4">
      <StakesCTAPulse
        client:visible
        href="https://tidycal.com/garyctate/15-minute-meeting"
        text="Book a Free Call"
      />
    </div>
  </div>
</section>
