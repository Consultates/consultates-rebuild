---
import HeroIsland from '../islands/HeroIsland.tsx';
import { TIDYCAL_URL } from '../../config';
---

<section id="section-hero" class="c-hero">
  <video
    class="c-hero-video"
    autoplay
    muted
    loop
    playsinline
    poster="/images/hero-poster.webp"
    aria-hidden="true"
  >
    <source src="/video/hero-bg.mp4" type="video/mp4" />
  </video>

  <div class="c-hero-overlay"></div>

  <div class="c-hero-content">
    <HeroIsland
      client:load
      tagline="AI Consulting"
      headline="Clarity on AI — what to do, where to start, and <em>who to trust</em>"
      paragraph="You're a leader who knows AI matters but can't separate the signal from the noise. You don't need more articles or another webinar. You need someone who builds with AI every day to sit down with you and make it practical."
      ctaHref={TIDYCAL_URL}
      ctaText="Book a Free Call"
    />
  </div>
</section>

<style>
  .c-hero {
    background: var(--hero-bg, #0D1117);
    color: var(--hero-fg, #E2E0EC);
    padding: clamp(6rem, 14vw, 10rem) 0 clamp(5rem, 12vw, 8rem);
    text-align: center;
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 4rem);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .c-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1);
    opacity: 0.3;
    pointer-events: none;
  }

  @media (max-width: 767px) {
    .c-hero-video {
      display: none;
    }
    .c-hero {
      background-image: url('/images/hero-poster.webp');
      background-size: cover;
      background-position: center;
    }
  }

  .c-hero-overlay {
    position: absolute;
    inset: 0;
    background: var(--hero-bg, #0D1117);
    opacity: 0.75;
    pointer-events: none;
  }

  /* Radial purple glow */
  .c-hero::before {
    content: '';
    position: absolute;
    top: 40%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(92,59,156,0.12) 0%, rgba(92,59,156,0.04) 40%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  /* Dot grid */
  .c-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(139,108,199,0.07) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
    z-index: 1;
  }

  .c-hero-content {
    position: relative;
    z-index: 2;
    max-width: var(--content-max, 1140px);
    margin: 0 auto;
    padding-left: var(--content-px, clamp(1.5rem, 4vw, 2.5rem));
    padding-right: var(--content-px, clamp(1.5rem, 4vw, 2.5rem));
  }

  /* Global styles that reach into the React island */
  :global(.c-hero-tagline) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--stakes-accent, #8B6CC7);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1.5rem;
  }

  :global(.c-hero-h1) {
    font-family: var(--font-serif);
    font-size: var(--text-hero, clamp(2.75rem, 5.5vw, 4rem));
    line-height: 1.08;
    letter-spacing: -0.025em;
    font-weight: 700;
    color: #FFFFFF;
    max-width: 820px;
    margin: 0 auto 1.75rem;
  }

  :global(.c-hero-h1 em) {
    font-style: normal;
    color: var(--stakes-accent, #8B6CC7);
  }

  :global(.c-hero-body) {
    font-size: var(--text-body-lg, clamp(1.0625rem, 1.5vw, 1.25rem));
    line-height: 1.65;
    color: var(--hero-muted, #7A7B90);
    max-width: 580px;
    margin: 0 auto 2.75rem;
  }

  :global(.c-hero-cta) {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.9375rem 2.25rem;
    background: var(--stakes-accent, #8B6CC7);
    color: #FFFFFF;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    border-radius: 99px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  :global(.c-hero-cta:hover) {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(139,108,199,0.3);
  }

  :global(.c-hero-cta .arrow) {
    transition: transform 0.2s;
  }

  :global(.c-hero-cta:hover .arrow) {
    transform: translateX(3px);
  }
</style>
