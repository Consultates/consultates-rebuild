---
import { SectionAnimator } from '../islands/SectionAnimator';
import UseCaseCardsIsland from '../islands/UseCaseCardsIsland';
---

<section id="section-cases" class="cases-section">
  <div class="max-w-[1200px] mx-auto" style="padding: 0 clamp(1.5rem, 5vw, 8rem);">
    <SectionAnimator client:visible delay={0.5}>
      <div class="text-center" style="margin-bottom: 3.5rem;">
        <h2 class="text-section text-foreground mb-4">What this looks like in practice</h2>
      </div>
    </SectionAnimator>

    <UseCaseCardsIsland client:visible />
  </div>
</section>

<style>
  .cases-section {
    padding: var(--section-py) 0;
    background: var(--secondary);
    position: relative;
  }

  /* Subtle top/bottom border to separate from adjacent white sections */
  .cases-section::before,
  .cases-section::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border) 20%, var(--border) 80%, transparent);
  }
  .cases-section::before { top: 0; }
  .cases-section::after { bottom: 0; }
</style>
