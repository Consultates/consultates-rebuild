---
interface Props {
  title: string;
  href: string;
  image?: string;
  categorySlug: string;
  categoryLabel: string;
  categoryIcon: string;
  date?: string;
  readingTime?: number;
  excerpt?: string;
  compact?: boolean;
}

const {
  title,
  href,
  image,
  categorySlug,
  categoryLabel,
  categoryIcon,
  date,
  readingTime,
  excerpt,
  compact = false,
} = Astro.props;

const placeholderImage = '/images/blog/placeholder.webp';
---

<a
  href={href}
  class="blog-card flex flex-col bg-card border border-border rounded-xl overflow-hidden transition-all duration-200 hover:border-primary hover:shadow-[var(--card-shadow-hover)] hover:-translate-y-1 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring h-full"
>
  {/* Featured image */}
  <div class="blog-card__image">
    <img
      src={image || placeholderImage}
      alt=""
      loading="lazy"
      class="w-full h-full object-cover"
    />
  </div>

  {/* Content */}
  <div class="blog-card__body">
    {/* Category pill */}
    <span class="blog-card__pill">
      <i class={`ph-duotone ${categoryIcon}`} style="font-size: 0.875rem;"></i>
      {categoryLabel}
    </span>

    {/* Title */}
    <h3 class="font-serif text-card-foreground mt-2 line-clamp-2" style="font-size: var(--text-sub, 1.125rem); line-height: 1.4;">{title}</h3>

    {/* Date + reading time */}
    {date && (
      <p class="text-muted-foreground mt-1" style="font-family: var(--font-mono); font-size: 0.75rem;">
        {date}{readingTime ? ` · ${readingTime} min read` : ''}
      </p>
    )}

    {/* Excerpt */}
    {excerpt && (
      <p class="text-muted-foreground mt-1 line-clamp-2" style="font-size: 0.875rem; line-height: 1.5;">{excerpt}</p>
    )}

    {/* Read link — bottom right */}
    <div class="mt-auto pt-3 text-right pr-2">
      <span class="btn-alive btn-alive--sm">Read</span>
    </div>
  </div>
</a>

<style>
  .blog-card__image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--secondary);
  }

  .blog-card__body {
    padding: 1rem 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog-card__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--primary) 12%, transparent);
    color: var(--primary);
  }
</style>
