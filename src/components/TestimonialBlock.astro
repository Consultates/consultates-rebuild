---
interface Props {
  quote: string;
  name: string;
  title: string;
}

const { quote, name, title } = Astro.props;
---

<blockquote class="relative border-l-[3px] border-primary pl-6">
  <span
    class="absolute -top-4 -left-2 font-serif font-bold text-[6rem] leading-none text-primary opacity-20 select-none pointer-events-none"
    aria-hidden="true">&ldquo;</span>
  <p class="text-body-lg font-serif italic text-foreground">{quote}</p>
  <p class="text-body font-semibold text-foreground mt-4">{name}</p>
  <p class="text-caption text-muted-foreground">{title}</p>
</blockquote>
