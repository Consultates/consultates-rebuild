---
interface Props {
  title: string;
  date: string;
  excerpt: string;
  href: string;
}

const { title, date, excerpt, href } = Astro.props;
---

<a
  href={href}
  class="block bg-card border border-border rounded-xl p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(0,0,0,0.08)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
>
  <h3 class="text-sub text-card-foreground mb-1">{title}</h3>
  <p class="text-cite text-muted-foreground mb-3">{date}</p>
  <p class="text-body text-muted-foreground mb-4 line-clamp-3">{excerpt}</p>
  <span class="text-body font-medium text-primary">Read &rarr;</span>
</a>
