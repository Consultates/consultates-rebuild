---
import ThemeToggle from './ThemeToggle.tsx';
import Button from './Button.astro';

const currentPath = Astro.url.pathname;
const isHomepage = currentPath === '/';

const links = [
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const services = [
  {
    href: '/services/ai-advisory-for-leaders',
    label: 'AI Advisory for Leaders',
    desc: '1:1 advisory for executives',
    icon: 'user-focus',
  },
  {
    href: '/services/ai-training-for-teams',
    label: 'AI Training for Teams',
    desc: 'Workshops for your organisation',
    icon: 'users-three',
  },
  {
    href: '/services/fractional-exec-support',
    label: 'Fractional Exec Support',
    desc: 'Embedded AI leadership on demand',
    icon: 'briefcase',
  },
];

const homeSections = [
  { index: 1, label: 'Stakes', desc: 'What you risk by waiting', icon: 'warning' },
  { index: 2, label: 'What We Offer', desc: 'Advisory, training & leadership', icon: 'squares-four' },
  { index: 3, label: 'Use Cases', desc: 'Real scenarios, real results', icon: 'lightbulb' },
  { index: 4, label: 'How It Works', desc: 'From first call to impact', icon: 'list-numbers' },
  { index: 5, label: 'Testimonials', desc: 'What clients say', icon: 'chat-circle-text' },
  { index: 6, label: 'Why Consultates', desc: 'What makes us different', icon: 'shield-check' },
  { index: 7, label: 'Get Started', desc: 'Book your free call', icon: 'rocket-launch' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

const isServicesActive = currentPath.startsWith('/services');
---

<!-- Desktop + Mobile Nav -->
<nav class="fixed top-0 left-0 right-0 z-50 border-b border-border/50" style="background: color-mix(in srgb, var(--background) 85%, transparent); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
  <div class="max-w-[1200px] mx-auto h-16 px-[clamp(1.5rem,5vw,8rem)] flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="shrink-0">
      <img src="/images/logo-light.webp" alt="Consultates" class="h-9 md:h-10 dark:hidden" />
      <img src="/images/logo-dark.webp" alt="Consultates" class="h-9 md:h-10 hidden dark:block" />
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center gap-6">

      <!-- Home — always shows dropdown with section navigation -->
      <div class="relative group">
        {isHomepage ? (
          <button
            id="home-nav-btn"
            class:list={[
              'text-body font-medium text-foreground hover:text-primary transition-colors duration-150 flex items-center gap-1',
              'border-b-2 border-primary pb-1',
            ]}
            type="button"
          >
            Home
            <!-- Phosphor CaretDown duotone -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256" class="transition-transform duration-200 group-hover:rotate-180">
              <path d="M208,96l-80,80L48,96Z" opacity="0.2"></path>
              <path d="M215.39,92.94A8,8,0,0,0,208,88H48a8,8,0,0,0-5.66,13.66l80,80a8,8,0,0,0,11.32,0l80-80A8,8,0,0,0,215.39,92.94ZM128,164.69,67.31,104H188.69Z"></path>
            </svg>
          </button>
        ) : (
          <a
            href="/"
            class="text-body font-medium text-foreground hover:text-primary transition-colors duration-150 flex items-center gap-1"
          >
            Home
            <!-- Phosphor CaretDown duotone -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256" class="transition-transform duration-200 group-hover:rotate-180">
              <path d="M208,96l-80,80L48,96Z" opacity="0.2"></path>
              <path d="M215.39,92.94A8,8,0,0,0,208,88H48a8,8,0,0,0-5.66,13.66l80,80a8,8,0,0,0,11.32,0l80-80A8,8,0,0,0,215.39,92.94ZM128,164.69,67.31,104H188.69Z"></path>
            </svg>
          </a>
        )}

        <!-- Section Navigation Panel -->
        <div class="absolute top-full left-0 mt-1 bg-card border border-border rounded-xl shadow-[0_10px_25px_rgba(0,0,0,0.1)] p-4 min-w-[280px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0">
          {homeSections.map((section) => {
            const itemContent = (
              <Fragment>
                {section.icon === 'warning' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256" class="shrink-0 text-primary">
                    <path d="M236.73,187.89,149.13,36.22h0a24.34,24.34,0,0,0-42.26,0L19.27,187.89A23.51,23.51,0,0,0,18,200.55,24.3,24.3,0,0,0,40.87,224H215.13A24.3,24.3,0,0,0,238,200.55,23.51,23.51,0,0,0,236.73,187.89Z" opacity="0.2"></path>
                    <path d="M236.8,188.09,149.35,36.22h0a24.76,24.76,0,0,0-42.7,0L19.2,188.09a23.51,23.51,0,0,0,0,23.72A24.35,24.35,0,0,0,40.55,224h174.9a24.35,24.35,0,0,0,21.33-12.19A23.51,23.51,0,0,0,236.8,188.09ZM222.93,203.8a8.5,8.5,0,0,1-7.48,4.2H40.55a8.5,8.5,0,0,1-7.48-4.2,7.59,7.59,0,0,1,0-7.72L120.52,44.21a8.75,8.75,0,0,1,15,0l87.45,151.87A7.59,7.59,0,0,1,222.93,203.8ZM120,144V104a8,8,0,0,1,16,0v40a8,8,0,0,1-16,0Zm20,36a12,12,0,1,1-12-12A12,12,0,0,1,140,180Z"></path>
                  </svg>
                )}
                {section.icon === 'squares-four' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256" class="shrink-0 text-primary">
                    <path d="M112,56v48a8,8,0,0,1-8,8H56a8,8,0,0,1-8-8V56a8,8,0,0,1,8-8h48A8,8,0,0,1,112,56Zm88-8H152a8,8,0,0,0-8,8v48a8,8,0,0,0,8,8h48a8,8,0,0,0,8-8V56A8,8,0,0,0,200,48Zm-96,96H56a8,8,0,0,0-8,8v48a8,8,0,0,0,8,8h48a8,8,0,0,0,8-8V152A8,8,0,0,0,104,144Zm96,0H152a8,8,0,0,0-8,8v48a8,8,0,0,0,8,8h48a8,8,0,0,0,8-8V152A8,8,0,0,0,200,144Z" opacity="0.2"></path>
                    <path d="M200,136H152a16,16,0,0,0-16,16v48a16,16,0,0,0,16,16h48a16,16,0,0,0,16-16V152A16,16,0,0,0,200,136Zm0,64H152V152h48v48ZM104,40H56A16,16,0,0,0,40,56v48a16,16,0,0,0,16,16h48a16,16,0,0,0,16-16V56A16,16,0,0,0,104,40Zm0,64H56V56h48v48Zm96-64H152a16,16,0,0,0-16,16v48a16,16,0,0,0,16,16h48a16,16,0,0,0,16-16V56A16,16,0,0,0,200,40Zm0,64H152V56h48v48Zm-96,32H56a16,16,0,0,0-16,16v48a16,16,0,0,0,16,16h48a16,16,0,0,0,16-16V152A16,16,0,0,0,104,136Zm0,64H56V152h48v48Z"></path>
                  </svg>
                )}
                {section.icon === 'lightbulb' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256" class="shrink-0 text-primary">
                    <path d="M208,104a79.86,79.86,0,0,1-30.59,62.92A24.29,24.29,0,0,0,168,186v6a8,8,0,0,1-8,8H96a8,8,0,0,1-8-8v-6a24.11,24.11,0,0,0-9.3-19A79.87,79.87,0,0,1,48,104.45C47.76,61.09,82.72,25,126.07,24A80,80,0,0,1,208,104Z" opacity="0.2"></path>
                    <path d="M176,232a8,8,0,0,1-8,8H88a8,8,0,0,1,0-16h80A8,8,0,0,1,176,232Zm40-128a87.55,87.55,0,0,1-33.64,69.21A16.24,16.24,0,0,0,176,186v6a16,16,0,0,1-16,16H96a16,16,0,0,1-16-16v-6a16,16,0,0,0-6.23-12.66A87.59,87.59,0,0,1,40,104.49C39.74,56.83,78.26,17.14,125.88,16A88,88,0,0,1,216,104Zm-16,0a72,72,0,0,0-73.74-72c-39,.92-70.47,33.39-70.26,72.39a71.65,71.65,0,0,0,27.64,56.3A32,32,0,0,1,96,186v6h64v-6a32.15,32.15,0,0,1,12.47-25.35A71.65,71.65,0,0,0,200,104Zm-16.11-9.34a57.6,57.6,0,0,0-46.56-46.55,8,8,0,0,0-2.66,15.78c16.57,2.79,30.63,16.85,33.44,33.45A8,8,0,0,0,176,104a9,9,0,0,0,1.35-.11A8,8,0,0,0,183.89,94.66Z"></path>
                  </svg>
                )}
                {section.icon === 'list-numbers' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256" class="shrink-0 text-primary">
                    <path d="M216,64V192H104V64Z" opacity="0.2"></path>
                    <path d="M224,128a8,8,0,0,1-8,8H104a8,8,0,0,1,0-16H216A8,8,0,0,1,224,128ZM104,72H216a8,8,0,0,0,0-16H104a8,8,0,0,0,0,16ZM216,184H104a8,8,0,0,0,0,16H216a8,8,0,0,0,0-16ZM43.58,55.16,48,52.94V104a8,8,0,0,0,16,0V40a8,8,0,0,0-11.58-7.16l-16,8a8,8,0,0,0,7.16,14.32ZM79.77,156.72a23.73,23.73,0,0,0-9.6-15.95,24.86,24.86,0,0,0-34.11,4.7,23.63,23.63,0,0,0-3.57,6.46,8,8,0,1,0,15,5.47,7.84,7.84,0,0,1,1.18-2.13,8.76,8.76,0,0,1,12-1.59A7.91,7.91,0,0,1,63.93,159a7.64,7.64,0,0,1-1.57,5.78,1,1,0,0,0-.08.11L33.59,203.21A8,8,0,0,0,40,216H72a8,8,0,0,0,0-16H56l19.08-25.53A23.47,23.47,0,0,0,79.77,156.72Z"></path>
                  </svg>
                )}
                {section.icon === 'chat-circle-text' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256" class="shrink-0 text-primary">
                    <path d="M224,128A96,96,0,0,1,79.93,211.11h0L42.54,223.58a8,8,0,0,1-10.12-10.12l12.47-37.39h0A96,96,0,1,1,224,128Z" opacity="0.2"></path>
                    <path d="M128,24A104,104,0,0,0,36.18,176.88L24.83,210.93a16,16,0,0,0,20.24,20.24l34.05-11.35A104,104,0,1,0,128,24Zm0,192a87.87,87.87,0,0,1-44.06-11.81,8,8,0,0,0-4-1.08,7.85,7.85,0,0,0-2.53.42L40,216,52.47,178.6a8,8,0,0,0-.66-6.54A88,88,0,1,1,128,216Zm40-104a8,8,0,0,1-8,8H96a8,8,0,0,1,0-16h64A8,8,0,0,1,168,112Zm0,32a8,8,0,0,1-8,8H96a8,8,0,0,1,0-16h64A8,8,0,0,1,168,144Z"></path>
                  </svg>
                )}
                {section.icon === 'shield-check' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256" class="shrink-0 text-primary">
                    <path d="M216,56v56c0,96-88,120-88,120S40,208,40,112V56a8,8,0,0,1,8-8H208A8,8,0,0,1,216,56Z" opacity="0.2"></path>
                    <path d="M208,40H48A16,16,0,0,0,32,56v56c0,52.72,25.52,84.67,46.93,102.19,23.06,18.86,46,25.26,47,25.53a8,8,0,0,0,4.2,0c1-.27,23.91-6.67,47-25.53C198.48,196.67,224,164.72,224,112V56A16,16,0,0,0,208,40Zm0,72c0,37.07-13.66,67.16-40.6,89.42A129.3,129.3,0,0,1,128,223.62a128.25,128.25,0,0,1-38.92-21.81C61.82,179.51,48,149.3,48,112l0-56,160,0ZM82.34,141.66a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35a8,8,0,0,1,11.32,11.32l-56,56a8,8,0,0,1-11.32,0Z"></path>
                  </svg>
                )}
                {section.icon === 'rocket-launch' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256" class="shrink-0 text-primary">
                    <path d="M184,120v61.65a8,8,0,0,1-2.34,5.65l-34.35,34.35a8,8,0,0,1-13.57-4.53L128,176ZM136,72H74.35a8,8,0,0,0-5.65,2.34L34.35,108.69a8,8,0,0,0,4.53,13.57L80,128ZM40,216c37.65,0,50.69-19.69,54.56-28.18L68.18,161.44C59.69,165.31,40,178.35,40,216Z" opacity="0.2"></path>
                    <path d="M223.85,47.12a16,16,0,0,0-15-15c-12.58-.75-44.73.4-71.41,27.07L132.69,64H74.36A15.91,15.91,0,0,0,63,68.68L28.7,103a16,16,0,0,0,9.07,27.16l38.47,5.37,44.21,44.21,5.37,38.49a15.94,15.94,0,0,0,10.78,12.92,16.11,16.11,0,0,0,5.1.83A15.91,15.91,0,0,0,153,227.3L187.32,193A15.91,15.91,0,0,0,192,181.64V123.31l4.77-4.77C223.45,91.86,224.6,59.71,223.85,47.12ZM74.36,80h42.33L77.16,119.52,40,114.34Zm74.41-9.45a76.65,76.65,0,0,1,59.11-22.47,76.46,76.46,0,0,1-22.42,59.16L128,164.68,91.32,128ZM176,181.64,141.67,216l-5.19-37.17L176,139.31Zm-74.16,9.5C97.34,201,82.29,224,40,224a8,8,0,0,1-8-8c0-42.29,23-57.34,32.86-61.85a8,8,0,0,1,6.64,14.56c-6.43,2.93-20.62,12.36-23.12,38.91,26.55-2.5,36-16.69,38.91-23.12a8,8,0,1,1,14.56,6.64Z"></path>
                  </svg>
                )}
                <div>
                  <span class="text-body font-medium text-foreground">{section.label}</span>
                  <span class="block text-caption text-muted-foreground">{section.desc}</span>
                </div>
              </Fragment>
            );
            return isHomepage ? (
              <button
                type="button"
                data-section-index={section.index}
                class="nav-section-btn w-full text-left flex gap-3 items-start p-3 rounded-lg hover:bg-muted transition-colors"
              >
                {itemContent}
              </button>
            ) : (
              <a
                href={`/?section=${section.index}`}
                class="w-full flex gap-3 items-start p-3 rounded-lg hover:bg-muted transition-colors"
              >
                {itemContent}
              </a>
            );
          })}
        </div>
      </div>

      <!-- Services Dropdown -->
      <div class="relative group">
        <button
          class:list={[
            'text-body font-medium text-foreground hover:text-primary transition-colors duration-150 flex items-center gap-1',
            isServicesActive && 'border-b-2 border-primary pb-1',
          ]}
          type="button"
        >
          Services
          <!-- Phosphor CaretDown duotone -->
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256" class="transition-transform duration-200 group-hover:rotate-180">
            <path d="M208,96l-80,80L48,96Z" opacity="0.2"></path>
            <path d="M215.39,92.94A8,8,0,0,0,208,88H48a8,8,0,0,0-5.66,13.66l80,80a8,8,0,0,0,11.32,0l80-80A8,8,0,0,0,215.39,92.94ZM128,164.69,67.31,104H188.69Z"></path>
          </svg>
        </button>

        <!-- Mega Menu Panel -->
        <div class="absolute top-full left-0 mt-1 bg-card border border-border rounded-xl shadow-[0_10px_25px_rgba(0,0,0,0.1)] p-4 min-w-[280px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0">
          {services.map((service) => (
            <a
              href={service.href}
              class="flex gap-3 items-start p-3 rounded-lg hover:bg-muted transition-colors"
            >
              <!-- Icon -->
              {service.icon === 'user-focus' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256" class="shrink-0 text-primary">
                  <path d="M228,128A100,100,0,1,1,128,28,100.11,100.11,0,0,1,228,128Z" opacity="0.2"></path>
                  <path d="M232,48V88a8,8,0,0,1-16,0V56H184a8,8,0,0,1,0-16h40A8,8,0,0,1,232,48ZM72,200H40V168a8,8,0,0,0-16,0v40a8,8,0,0,0,8,8H72a8,8,0,0,0,0-16Zm152-40a8,8,0,0,0-8,8v32H184a8,8,0,0,0,0,16h40a8,8,0,0,0,8-8V168A8,8,0,0,0,224,160ZM32,96a8,8,0,0,0,8-8V56H72a8,8,0,0,0,0-16H32A8,8,0,0,0,24,48V88A8,8,0,0,0,32,96Zm96,64a32,32,0,1,0-32-32A32,32,0,0,0,128,160Z"></path>
                </svg>
              )}
              {service.icon === 'users-three' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256" class="shrink-0 text-primary">
                  <path d="M164,136a36,36,0,1,1-36-36A36,36,0,0,1,164,136ZM36,108a28,28,0,1,0,28-28A28,28,0,0,0,36,108Zm156,0a28,28,0,1,0,28-28A28,28,0,0,0,192,108Z" opacity="0.2"></path>
                  <path d="M244.8,150.4a8,8,0,0,1-11.2-1.6A51.6,51.6,0,0,0,192,128a8,8,0,0,1,0-16,24,24,0,1,0-23.6-28.5,8,8,0,1,1-15.7-3A40,40,0,1,1,212,128a67.55,67.55,0,0,1,34.4,21.6A8,8,0,0,1,244.8,150.4ZM190.9,212a8,8,0,1,1-13.8,8,57,57,0,0,0-98.2,0,8,8,0,1,1-13.8-8,72.1,72.1,0,0,1,30.5-27.8,44,44,0,1,1,64.8,0A72.1,72.1,0,0,1,190.9,212ZM128,176a28,28,0,1,0-28-28A28,28,0,0,0,128,176ZM64,128a8,8,0,0,0,0-16,24,24,0,1,1,23.6-28.5,8,8,0,1,0,15.7-3A40,40,0,1,0,44,128a67.55,67.55,0,0,0-34.4,21.6,8,8,0,0,0,12.8,9.6A51.6,51.6,0,0,1,64,128Z"></path>
                </svg>
              )}
              {service.icon === 'briefcase' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256" class="shrink-0 text-primary">
                  <path d="M224,72V200a8,8,0,0,1-8,8H40a8,8,0,0,1-8-8V72a8,8,0,0,1,8-8H216A8,8,0,0,1,224,72Z" opacity="0.2"></path>
                  <path d="M216,56H176V48a24,24,0,0,0-24-24H104A24,24,0,0,0,80,48v8H40A16,16,0,0,0,24,72V200a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V72A16,16,0,0,0,216,56ZM96,48a8,8,0,0,1,8-8h48a8,8,0,0,1,8,8v8H96ZM216,200H40V72H216V200Z"></path>
                </svg>
              )}
              <div>
                <span class="text-body font-medium text-foreground">{service.label}</span>
                <span class="block text-caption text-muted-foreground">{service.desc}</span>
              </div>
            </a>
          ))}
        </div>
      </div>

      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-body font-medium text-foreground hover:text-primary transition-colors duration-150',
            isActive(link.href) && 'border-b-2 border-primary pb-1',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Right side -->
    <div class="flex items-center gap-2">
      <ThemeToggle client:load />
      <div class="hidden md:inline-flex">
        <Button variant="cta" href="https://tidycal.com/garyctate/15-minute-meeting" target="_blank" rel="noopener">
          Book a Free Call
        </Button>
      </div>
      <img
        src="/images/gary-nav-avatar.webp"
        alt="Gary Tate"
        width="36"
        height="36"
        class="hidden md:block rounded-full ml-1"
      />
      <!-- Hamburger (mobile) -->
      <button id="nav-hamburger" class="md:hidden w-10 h-10 flex items-center justify-center rounded-lg hover:bg-muted transition-colors duration-150 text-foreground" aria-label="Open menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256">
          <path d="M224,128a8,8,0,0,1-8,8H40a8,8,0,0,1,0-16H216A8,8,0,0,1,224,128ZM40,72H216a8,8,0,0,0,0-16H40a8,8,0,0,0,0,16ZM216,184H40a8,8,0,0,0,0,16H216a8,8,0,0,0,0-16Z"></path>
        </svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-40 bg-background flex flex-col items-center justify-center gap-6 hidden">
  <!-- Close button -->
  <button id="mobile-close" class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center rounded-lg hover:bg-muted transition-colors duration-150 text-foreground" aria-label="Close menu">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256">
      <path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"></path>
    </svg>
  </button>

  <!-- Mobile: Home with expandable section sub-items (all pages) -->
  <div class="flex flex-col items-center gap-2">
    <button id="home-toggle-mobile" class:list={['text-[1.125rem] font-medium transition-colors flex items-center gap-1', isHomepage ? 'text-primary' : 'text-foreground hover:text-primary']}>
      Home
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256">
        <path d="M208,96l-80,80L48,96Z" opacity="0.2"></path>
        <path d="M215.39,92.94A8,8,0,0,0,208,88H48a8,8,0,0,0-5.66,13.66l80,80a8,8,0,0,0,11.32,0l80-80A8,8,0,0,0,215.39,92.94ZM128,164.69,67.31,104H188.69Z"></path>
      </svg>
    </button>
    <div id="home-submenu-mobile" class="hidden flex flex-col items-center gap-2 mt-1">
      {homeSections.map((section) => (
        isHomepage ? (
          <button
            type="button"
            data-section-index={section.index}
            class="nav-section-btn text-body text-muted-foreground hover:text-primary transition-colors"
          >
            {section.label}
          </button>
        ) : (
          <a
            href={`/?section=${section.index}`}
            class="text-body text-muted-foreground hover:text-primary transition-colors"
          >
            {section.label}
          </a>
        )
      ))}
    </div>
  </div>

  <!-- Services with sub-items -->
  <div class="flex flex-col items-center gap-2">
    <button id="services-toggle-mobile" class:list={['text-[1.125rem] font-medium text-foreground hover:text-primary transition-colors flex items-center gap-1', isServicesActive && 'text-primary']}>
      Services
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256">
        <path d="M208,96l-80,80L48,96Z" opacity="0.2"></path>
        <path d="M215.39,92.94A8,8,0,0,0,208,88H48a8,8,0,0,0-5.66,13.66l80,80a8,8,0,0,0,11.32,0l80-80A8,8,0,0,0,215.39,92.94ZM128,164.69,67.31,104H188.69Z"></path>
      </svg>
    </button>
    <div id="services-submenu-mobile" class="hidden flex flex-col items-center gap-2 mt-1">
      {services.map((service) => (
        <a href={service.href} class="text-body text-muted-foreground hover:text-primary transition-colors">
          {service.label}
        </a>
      ))}
    </div>
  </div>

  {links.map((link) => (
    <a
      href={link.href}
      class:list={[
        'text-[1.125rem] font-medium text-foreground hover:text-primary transition-colors',
        isActive(link.href) && 'text-primary',
      ]}
    >
      {link.label}
    </a>
  ))}

  <!-- Mobile CTA -->
  <div class="mt-4">
    <Button variant="cta" href="https://tidycal.com/garyctate/15-minute-meeting" target="_blank" rel="noopener">
      Book a Free Call
    </Button>
  </div>

  <!-- Mobile ThemeToggle -->
  <div class="mt-2">
    <ThemeToggle client:load />
  </div>
</div>

<script>
  // Mobile menu toggle
  const hamburger = document.getElementById('nav-hamburger');
  const menu = document.getElementById('mobile-menu');
  const close = document.getElementById('mobile-close');

  hamburger?.addEventListener('click', () => {
    menu?.classList.remove('hidden');
    document.body.classList.add('nav-open');
  });

  close?.addEventListener('click', () => {
    menu?.classList.add('hidden');
    document.body.classList.remove('nav-open');
  });

  // Close on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      document.body.classList.remove('nav-open');
    });
  });

  // Services dropdown on mobile (tap to toggle)
  const servicesToggle = document.getElementById('services-toggle-mobile');
  const servicesSubmenu = document.getElementById('services-submenu-mobile');
  servicesToggle?.addEventListener('click', (e) => {
    e.preventDefault();
    servicesSubmenu?.classList.toggle('hidden');
  });

  // Home sections dropdown on mobile (tap to toggle)
  const homeToggle = document.getElementById('home-toggle-mobile');
  const homeSubmenu = document.getElementById('home-submenu-mobile');
  homeToggle?.addEventListener('click', (e) => {
    e.preventDefault();
    homeSubmenu?.classList.toggle('hidden');
  });

  // Home button on homepage — clicking scrolls to hero (section 0)
  const homeNavBtn = document.getElementById('home-nav-btn');
  homeNavBtn?.addEventListener('click', () => {
    if (typeof (window as any).scrollToSection === 'function') {
      (window as any).scrollToSection(0);
    }
  });

  // Section navigation buttons — both desktop and mobile
  document.querySelectorAll('.nav-section-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const index = parseInt((btn as HTMLElement).dataset.sectionIndex || '0', 10);
      if (typeof (window as any).scrollToSection === 'function') {
        (window as any).scrollToSection(index);
      }
      // Close mobile menu if open
      menu?.classList.add('hidden');
      document.body.classList.remove('nav-open');
    });
  });
</script>
