---
interface Props {
  label: string;
  name: string;
  type?: string;
  required?: boolean;
  error?: string;
  textarea?: boolean;
  placeholder?: string;
  disabled?: boolean;
}

const {
  label,
  name,
  type = 'text',
  required = false,
  error,
  textarea = false,
  placeholder,
  disabled = false,
} = Astro.props;

const fieldClasses = [
  'bg-card border rounded-lg px-3 py-2.5 font-sans text-base text-foreground',
  'placeholder:text-muted-foreground',
  'focus:outline-2 focus:outline-offset-0 focus:outline-ring',
  'disabled:opacity-50 disabled:cursor-not-allowed',
  error ? 'border-destructive' : 'border-border',
].join(' ');
---

<div class="flex flex-col gap-1">
  <label for={name} class="text-caption font-medium text-foreground">{label}</label>
  {textarea ? (
    <textarea
      id={name}
      name={name}
      placeholder={placeholder}
      required={required}
      disabled={disabled}
      rows="5"
      class={fieldClasses}
    />
  ) : (
    <input
      id={name}
      name={name}
      type={type}
      placeholder={placeholder}
      required={required}
      disabled={disabled}
      class={fieldClasses}
    />
  )}
  {error && <p class="text-cite text-destructive">{error}</p>}
</div>
